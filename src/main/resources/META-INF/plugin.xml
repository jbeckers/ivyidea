<idea-plugin url="http://www.ivyidea.org">
  <name>IvyIDEA</name>
  <!--<id></id>-->
  <!--<description></description>-->
  <!--<change-notes></change-notes>-->
  <!--<version></version>-->
  <vendor email="guy.mahieu@gmail.com" url="http://www.ivyidea.org">
    Guy Mahieu
  </vendor>
  <!--<idea-version since-build="3000"/>-->
  <actions>
    <group id="IvyIDEA.Menu" text="IvyIDEA" description="Resolve module dependencies using Ivy"
      popup="true">
      <add-to-group group-id="EditorPopupMenu" anchor="last"/>
      <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
      <add-to-group group-id="ToolsMenu" anchor="first"/>
      <separator/>
      <action id="IvyIDEA.UpdateSingleModuleDependencies"
        class="org.clarent.ivyidea.action.ResolveForActiveModuleAction"
        text="Resolve for Active Module"
        description="Resolve dependencies for the active module">
      </action>
      <action id="IvyIDEA.UpdateAllDependencies"
        class="org.clarent.ivyidea.action.ResolveForAllModulesAction"
        text="Resolve for All Modules"
        description="Resolve dependencies for all modules">
      </action>
      <separator/>
      <action id="ivyidea.RemoveAllIvyIdeaModuleLibrariesAction"
        class="org.clarent.ivyidea.action.RemoveAllIvyIdeaModuleLibrariesAction"
        text="Remove All Resolved Libraries"
        description="Remove all module libraries generated by IvyIDEA."/>
    </group>
  </actions>
  <extensions defaultExtensionNs="com.intellij">
    <applicationService
      serviceImplementation="org.clarent.ivyidea.IvyIdeaPlugin"/>
    <projectService
      serviceImplementation="org.clarent.ivyidea.settings.IvyIdeaProjectStateComponent"/>
    <toolWindow
      id="IvyIDEA"
      icon="/ivyidea13.png"
      anchor="bottom"
      factoryClass="org.clarent.ivyidea.toolwindow.IvyIdeaToolWindowFactory"/>
    <facetType
      implementation="org.clarent.ivyidea.facet.IvyIdeaFacetType"/>
    <framework.detector
      implementation="org.clarent.ivyidea.facet.IvyIdeaFacetDetector"/>
    <projectConfigurable id="IvyIDEA.ProjectSettings"
      instance="org.clarent.ivyidea.settings.IvyIdeaProjectConfigurable"
      displayName="IvyIDEA"/>
  </extensions>
</idea-plugin>

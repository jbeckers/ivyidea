<idea-plugin url="http://www.ivyidea.org">
  <name>IvyIDEA</name>
  <!--<id></id>-->
  <!--<description></description>-->
  <!--<change-notes></change-notes>-->
  <!--<version></version>-->
  <vendor email="guy.mahieu@gmail.com" url="https://github.com/guymahieu/ivyidea"
    logo="/ivyidea16.png">
    Guy Mahieu
  </vendor>
  <!--<idea-version since-build="3000"/>-->
  <actions>
    <group id="IvyIDEA.Menu" text="IvyIDEA" description="Resolve module dependencies using Ivy"
      popup="true">
      <add-to-group group-id="EditorPopupMenu" anchor="last"/>
      <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
      <add-to-group group-id="ToolsMenu" anchor="first"/>
      <separator/>
      <action id="IvyIDEA.UpdateSingleModuleDependencies"
        class="org.clarent.ivyidea.ResolveForActiveModuleAction" text="Resolve for Active Module"
        description="Resolve dependencies for the active module">
      </action>
      <action id="IvyIDEA.UpdateAllDependencies"
        class="org.clarent.ivyidea.ResolveForAllModulesAction" text="Resolve for All Modules"
        description="Resolve dependencies for all modules">
      </action>
      <separator/>
      <action id="ivyidea.RemoveAllIvyIdeaModuleLibrariesAction"
        class="org.clarent.ivyidea.RemoveAllIvyIdeaModuleLibrariesAction"
        text="Remove All Resolved Libraries"
        description="Remove all module libraries generated by IvyIDEA."/>
    </group>
  </actions>
  <extensions defaultExtensionNs="com.intellij">
    <applicationService
      serviceInterface="org.clarent.ivyidea.IvyIdeaPlugin"
      serviceImplementation="org.clarent.ivyidea.IvyIdeaPluginImpl"/>
    <projectService
      serviceInterface="org.clarent.ivyidea.intellij.IvyIdeaProjectComponent"
      serviceImplementation="org.clarent.ivyidea.intellij.IvyIdeaProjectComponentImpl"/>
    <projectService
      serviceInterface="org.clarent.ivyidea.intellij.ToolWindowRegistrationComponent"
      serviceImplementation="org.clarent.ivyidea.intellij.ToolWindowRegistrationComponentImpl"/>
    <facetType
      implementation="org.clarent.ivyidea.intellij.facet.IvyIdeaFacetType"/>
    <framework.detector
      implementation="org.clarent.ivyidea.intellij.facet.IvyIdeaFacetDetector"/>
    <projectConfigurable id="IvyIDEA.ProjectSettings"
      instance="org.clarent.ivyidea.intellij.ui.IvyIdeaProjectSettingsComponent"
      displayName="IvyIDEA"/>
  </extensions>
</idea-plugin>
